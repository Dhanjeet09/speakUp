{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npx turbo build --scope=@speakup/web --include-dependencies",
  "outputDirectory": ".next",
  "devCommand": "next dev --port 3000",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}