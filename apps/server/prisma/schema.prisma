generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FriendshipStatus {
  pending
  accepted
  rejected
}

enum EnglishLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum ReportReason {
  inappropriate_language
  harassment
  spam
  other
}

enum UserRole {
  learner
  moderator
  admin
}

model User {
  id             String       @id
  email          String       @unique
  role           UserRole     @default(learner)
  name           String?
  username       String?      @unique
  country        String?
  timezone       String?
  nativeLanguage String?
  bio            String?
  avatarUrl      String?
  englishLevel   EnglishLevel?
  interests      String[]
  createdAt      DateTime     @default(now())
  totalMinutes   Int          @default(0)
  totalSessions  Int          @default(0)
  currentStreak  Int          @default(0)
  lastSessionDate DateTime?
  isSuspended    Boolean      @default(false)
  suspendedAt    DateTime?
  suspensionReason String?

  sessionsAsUser1 Session[]    @relation("User1Sessions")
  sessionsAsUser2 Session[]    @relation("User2Sessions")
  blocksMade      Block[]      @relation("BlockerBlocks")
  blocksReceived  Block[]      @relation("BlockedBlocks")
  reportsMade     Report[]     @relation("ReporterReports")
  reportsReceived Report[]     @relation("ReportedReports")
  messagesSent    ChatMessage[] @relation("SenderMessages")
  messagesReceived ChatMessage[] @relation("ReceiverMessages")
  friendRequestsSent     Friendship[] @relation("SentFriendRequests")
  friendRequestsReceived Friendship[] @relation("ReceivedFriendRequests")

  @@index([email])
  @@index([englishLevel])
  @@index([username])
  @@index([totalSessions])
}

model Session {
  id              String      @id @default(cuid())
  createdAt       DateTime    @default(now())
  durationSeconds Int         @default(0)
  user1Id         String
  user2Id         String
  topicUsed       String?
  user1Rating     Boolean?
  user2Rating     Boolean?
  roomUrl         String?

  user1 User @relation("User1Sessions", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("User2Sessions", fields: [user2Id], references: [id], onDelete: Cascade)

  @@index([user1Id, createdAt])
  @@index([user2Id, createdAt])
  @@index([createdAt])
}

model ChatMessage {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  sender   User @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceiverMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([senderId, receiverId, createdAt])
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("SentFriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("ReceivedFriendRequests", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlockerBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedBlocks", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  reportedId String
  reason     ReportReason
  note       String?
  createdAt  DateTime     @default(now())
  resolved   Boolean      @default(false)

  reporter User @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("ReportedReports", fields: [reportedId], references: [id], onDelete: Cascade)

  @@index([resolved, createdAt])
  @@index([reportedId])
}
