# ── Database (Required) ──
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/postgres

# ── Supabase (Required) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_here
SUPABASE_ANON_KEY=anon_key_here

# ── Server (Required) ──
PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# ── Web / Next.js (Required by client app) ──
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=anon_key_here
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# ── Socket Auth ──
# SUPABASE_JWT_SECRET=<your-supabase-jwt-secret>  # Verifies socket JWTs locally (avoids per-connection Supabase API calls)

# ── Sentry (Optional) ──
SENTRY_DSN=
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# NEXT_PUBLIC_SENTRY_DSN=

# ── Logging (Optional) ──
LOG_LEVEL=info

# ── Admin (Optional) ──
# ADMIN_USER_IDS=comma,separated,user,ids
