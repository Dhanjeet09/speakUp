    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "peer": "^1.0.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "sanitize-html": "^2.13.0",
    "socket.io": "^4.8.0",
    "zod": "^3.23.0"
